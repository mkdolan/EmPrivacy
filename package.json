{
  "//": "SPDX-License-Identifier: MIT",
  "name": "emprivacy",
  "version": "0.1.5",
  "description": "Cookie consent and privacy notices for EmDash (GDPR, CCPA/CIPA-oriented configuration)",
  "type": "module",
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./sandbox": "./dist/sandbox-entry.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "keywords": [
    "emdash",
    "cms",
    "plugin",
    "privacy",
    "cookie",
    "consent",
    "gdpr",
    "ccpa",
    "cmp"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "emdash": "^0.5.0"
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "emdash": "^0.5.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emdash-cms/EmPrivacy.git"
  },
  "bugs": {
    "url": "https://github.com/emdash-cms/EmPrivacy/issues"
  },
  "homepage": "https://github.com/emdash-cms/EmPrivacy#readme",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "kysely": "0.28.16"
  },
  "scripts": {
    "sync:version": "node scripts/write-version.mjs",
    "verify:exports": "node scripts/verify-exports.mjs",
    "build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
    "dev": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run sync:version && npm run typecheck && npm run build && npm test && npm run verify:exports && npm run audit",
    "preversion": "npm run sync:version && npm run typecheck && npm run build && npm test && npm run verify:exports && npm run audit",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "engines": {
    "node": ">=20"
  }
}
